<Window x:Class="KomaForge.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KomaForge - Comic Layout"
        Width="1280"
        Height="820"
        MinWidth="980"
        MinHeight="640"
        Background="{StaticResource WindowBackgroundBrush}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="InspectorColumn" Width="360" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border x:Name="InspectorPanel"
                Grid.Column="0"
                Background="#FFFFFF"
                BorderBrush="#DDD8CE"
                BorderThickness="0,0,1,0"
                Padding="16">
            <ScrollViewer x:Name="InspectorScrollViewer"
                          VerticalScrollBarVisibility="Auto"
                          PreviewMouseWheel="InspectorScrollViewer_PreviewMouseWheel">
                <StackPanel Margin="0,0,12,0">
                    <UniformGrid Rows="1" Columns="4" Margin="0,0,0,8">
                        <Button Content="저장"
                                Click="SaveProject_Click"
                                Margin="0,0,4,0" />
                        <Button Content="불러오기"
                                Click="LoadProject_Click"
                                Margin="0,0,4,0" />
                        <Button x:Name="UndoButton"
                                Content="↶ 실행취소"
                                Click="Undo_Click"
                                ToolTip="실행 취소 (Ctrl+Z)"
                                Margin="0,0,4,0" />
                        <Button x:Name="RedoButton"
                                Content="↷ 다시실행"
                                Click="Redo_Click"
                                ToolTip="다시 실행 (Ctrl+Y)"
                                Margin="0" />
                    </UniformGrid>
                    <Button Content="페이지 이미지로 내보내기"
                            Click="ExportPagesAsImages_Click"
                            ToolTip="각 페이지를 PNG 이미지 한 장씩으로 내보냅니다."
                            Margin="0,0,0,12" />

                    <TextBlock Text="만화 제목"
                               Foreground="#55514A"
                               Margin="0,0,0,6" />
                    <TextBox x:Name="ComicTitleTextBox"
                             MinHeight="34"
                             Padding="8,5"
                             VerticalContentAlignment="Center"
                             TextChanged="ComicTitleTextBox_TextChanged"
                             Margin="0,0,0,18" />

                    <CheckBox x:Name="PageFitCheckBox"
                              Content="페이지 쪽 맞춤"
                              IsChecked="False"
                              Checked="PageFitCheckBox_Changed"
                              Unchecked="PageFitCheckBox_Changed"
                              Margin="0,0,0,16" />

                    <Border Style="{StaticResource InspectorSection}">
                    <StackPanel>
                    <TextBlock Text="페이지" Style="{StaticResource SectionHeader}" />
                    <ListBox x:Name="PageListBox"
                             MinHeight="86"
                             MaxHeight="150"
                             SelectionChanged="PageListBox_SelectionChanged"
                             Margin="0,0,0,8" />
                    <UniformGrid Rows="1" Columns="4" Margin="0,0,0,18">
                        <Button Content="추가"
                                Click="AddPage_Click"
                                Margin="0,0,4,0" />
                        <Button Content="삭제"
                                Click="DeletePage_Click"
                                Margin="0,0,4,0" />
                        <Button Content="위로"
                                Click="MovePageUp_Click"
                                Margin="0,0,4,0" />
                        <Button Content="아래로"
                                Click="MovePageDown_Click"
                                Margin="0" />
                    </UniformGrid>

                    <TextBlock Text="페이지 크기 (너비 × 높이)"
                               Foreground="#55514A"
                               Margin="0,0,0,6" />
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBox x:Name="PageWidthTextBox"
                                 Text="820"
                                 Width="70"
                                 MinHeight="34"
                                 Padding="8,5"
                                 VerticalContentAlignment="Center"
                                 TextChanged="PageSizeTextBox_TextChanged" />
                        <TextBlock Text="×"
                                   VerticalAlignment="Center"
                                   Margin="6,0"
                                   Foreground="#55514A" />
                        <TextBox x:Name="PageHeightTextBox"
                                 Text="1120"
                                 Width="70"
                                 MinHeight="34"
                                 Padding="8,5"
                                 VerticalContentAlignment="Center"
                                 TextChanged="PageSizeTextBox_TextChanged" />
                    </StackPanel>
                    <CheckBox x:Name="BlackBackgroundCheckBox"
                              Content="페이지 배경 검은색"
                              IsChecked="False"
                              Checked="BlackBackgroundCheckBox_Changed"
                              Unchecked="BlackBackgroundCheckBox_Changed"
                              Margin="0,2,0,0" />
                    </StackPanel>
                    </Border>

                    <Border x:Name="PanelSectionBorder" Style="{StaticResource InspectorSection}">
                    <StackPanel>
                    <TextBlock Text="칸" Style="{StaticResource SectionHeader}" />

                    <TextBlock Text="선택한 칸"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}"
                               Margin="0,0,0,8" />
                    <ListBox x:Name="PanelListBox"
                             MinHeight="100"
                             MaxHeight="170"
                             SelectionChanged="PanelListBox_SelectionChanged"
                             Margin="0,0,0,8" />
                    <UniformGrid Rows="1" Columns="4" Margin="0,0,0,12">
                        <Button Content="추가"
                                Click="AddPanel_Click"
                                Margin="0,0,4,0" />
                        <Button Content="삭제"
                                Click="DeletePanel_Click"
                                Margin="0,0,4,0" />
                        <Button Content="위로"
                                Click="MovePanelUp_Click"
                                Margin="0,0,4,0" />
                        <Button Content="아래로"
                                Click="MovePanelDown_Click"
                                Margin="0" />
                    </UniformGrid>
                    <CheckBox x:Name="PanelLockCheckBox"
                              Content="고정 (선택·이동 잠금)"
                              IsChecked="False"
                              Checked="PanelLockCheckBox_Changed"
                              Unchecked="PanelLockCheckBox_Changed"
                              Margin="0,0,0,8" />
                    <CheckBox x:Name="PanelCornerModeCheckBox"
                              Content="모서리 조절 (사변형)"
                              IsChecked="False"
                              Checked="PanelCornerModeCheckBox_Changed"
                              Unchecked="PanelCornerModeCheckBox_Changed"
                              Margin="0,0,0,16" />

                    <TextBlock Text="칸 구성 / 여백 / 간격"
                               Foreground="#55514A"
                               Margin="0,0,0,6" />
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBox x:Name="LayoutPatternTextBox"
                                 Text="1,2,1"
                                 Width="116"
                                 MinHeight="34"
                                 Padding="8,5"
                                 VerticalContentAlignment="Center"
                                 ToolTip="칸 구성 (예: 1,2,1)" />
                        <TextBox x:Name="AutoMarginTextBox"
                                 Text="24"
                                 Width="56"
                                 MinHeight="34"
                                 Padding="8,5"
                                 VerticalContentAlignment="Center"
                                 Margin="8,0,0,0"
                                 ToolTip="자동 생성 여백" />
                        <TextBox x:Name="AutoGutterTextBox"
                                 Text="14"
                                 Width="56"
                                 MinHeight="34"
                                 Padding="8,5"
                                 VerticalContentAlignment="Center"
                                 Margin="8,0,0,0"
                                 ToolTip="자동 생성 간격" />
                    </StackPanel>
                    <Button Content="생성"
                            Click="ApplyLayout_Click"
                            HorizontalAlignment="Stretch"
                            Margin="0,0,0,8" />

                    <TextBlock x:Name="LayoutSummaryText"
                               Foreground="#55514A"
                               Margin="0,0,0,0" />
                    </StackPanel>
                    </Border>

                    <Border x:Name="ImageSectionBorder" Style="{StaticResource InspectorSection}">
                    <StackPanel>
                    <TextBlock Text="이미지" Style="{StaticResource SectionHeader}" />
                    <TextBlock Text="선택한 칸의 이미지"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}"
                               Margin="0,0,0,8" />
                    <ListBox x:Name="ImageListBox"
                             MinHeight="86"
                             MaxHeight="150"
                             SelectionChanged="ImageListBox_SelectionChanged"
                             Margin="0,0,0,8" />
                    <UniformGrid Rows="1" Columns="4" Margin="0,0,0,18">
                        <Button Content="추가"
                                Click="AddImageToPanel_Click"
                                Margin="0,0,4,0" />
                        <Button Content="삭제"
                                Click="ClearPanelImage_Click"
                                Margin="0,0,4,0" />
                        <Button Content="위로"
                                Click="MoveImageUp_Click"
                                Margin="0,0,4,0" />
                        <Button Content="아래로"
                                Click="MoveImageDown_Click"
                                Margin="0" />
                    </UniformGrid>
                    <CheckBox x:Name="ImageCropCheckBox"
                              Content="칸 경계에서 자르기"
                              IsChecked="True"
                              Checked="ImageCropCheckBox_Changed"
                              Unchecked="ImageCropCheckBox_Changed"
                              Margin="0,0,0,8" />
                    <CheckBox x:Name="ImageLockCheckBox"
                              Content="고정 (선택·이동 잠금)"
                              IsChecked="False"
                              Checked="ImageLockCheckBox_Changed"
                              Unchecked="ImageLockCheckBox_Changed"
                              Margin="0,0,0,18" />

                    <StackPanel Visibility="Collapsed">
                        <TextBlock Text="칸 위치와 크기"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextBrush}"
                                   Margin="0,0,0,8" />
                        <TextBlock x:Name="PanelXText" Foreground="#55514A" />
                        <Slider x:Name="PanelXSlider"
                                Minimum="0"
                                Maximum="760"
                                Value="40"
                                ValueChanged="PanelSlider_ValueChanged"
                                Margin="0,4,0,8" />
                        <TextBlock x:Name="PanelYText" Foreground="#55514A" />
                        <Slider x:Name="PanelYSlider"
                                Minimum="0"
                                Maximum="1040"
                                Value="40"
                                ValueChanged="PanelSlider_ValueChanged"
                                Margin="0,4,0,8" />
                        <TextBlock x:Name="PanelWidthText" Foreground="#55514A" />
                        <Slider x:Name="PanelWidthSlider"
                                Minimum="120"
                                Maximum="760"
                                Value="340"
                                ValueChanged="PanelSlider_ValueChanged"
                                Margin="0,4,0,8" />
                        <TextBlock x:Name="PanelHeightText" Foreground="#55514A" />
                        <Slider x:Name="PanelHeightSlider"
                                Minimum="120"
                                Maximum="520"
                                Value="300"
                                ValueChanged="PanelSlider_ValueChanged"
                                Margin="0,4,0,18" />
                    </StackPanel>
                    </StackPanel>
                    </Border>

                    <Border x:Name="BubbleSectionBorder" Style="{StaticResource InspectorSection}">
                    <StackPanel>
                    <TextBlock Text="말풍선" Style="{StaticResource SectionHeader}" />
                    <TextBlock Text="선택한 칸의 말풍선"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}"
                               Margin="0,0,0,8" />
                    <ListBox x:Name="BubbleListBox"
                             MinHeight="86"
                             MaxHeight="150"
                             SelectionChanged="BubbleListBox_SelectionChanged"
                             Margin="0,0,0,8" />
                    <UniformGrid Rows="1" Columns="4" Margin="0,0,0,12">
                        <Button Content="추가"
                                Click="AddBubble_Click"
                                Margin="0,0,4,0" />
                        <Button Content="삭제"
                                Click="DeleteBubble_Click"
                                Margin="0,0,4,0" />
                        <Button Content="위로"
                                Click="MoveBubbleUp_Click"
                                Margin="0,0,4,0" />
                        <Button Content="아래로"
                                Click="MoveBubbleDown_Click"
                                Margin="0" />
                    </UniformGrid>
                    <CheckBox x:Name="BubbleCropCheckBox"
                              Content="칸 경계에서 자르기"
                              IsChecked="True"
                              Checked="BubbleCropCheckBox_Changed"
                              Unchecked="BubbleCropCheckBox_Changed"
                              Margin="0,0,0,8" />
                    <CheckBox x:Name="BubbleLockCheckBox"
                              Content="고정 (선택·이동 잠금)"
                              IsChecked="False"
                              Checked="BubbleLockCheckBox_Changed"
                              Unchecked="BubbleLockCheckBox_Changed"
                              Margin="0,0,0,8" />
                    <CheckBox x:Name="BubbleOutlineCheckBox"
                              Content="글자 아웃라인"
                              IsChecked="False"
                              Checked="BubbleOutlineCheckBox_Changed"
                              Unchecked="BubbleOutlineCheckBox_Changed"
                              Margin="0,0,0,8" />
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock Text="글자색"
                                   Width="64"
                                   VerticalAlignment="Center"
                                   Foreground="#55514A" />
                        <ComboBox x:Name="BubbleFillColorComboBox"
                                  Width="130"
                                  SelectionChanged="BubbleFillColorComboBox_SelectionChanged" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock Text="아웃라인색"
                                   Width="64"
                                   VerticalAlignment="Center"
                                   Foreground="#55514A" />
                        <ComboBox x:Name="BubbleStrokeColorComboBox"
                                  Width="130"
                                  SelectionChanged="BubbleStrokeColorComboBox_SelectionChanged" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock Text="배경색"
                                   Width="64"
                                   VerticalAlignment="Center"
                                   Foreground="#55514A" />
                        <ComboBox x:Name="BubbleBackgroundColorComboBox"
                                  Width="130"
                                  SelectionChanged="BubbleBackgroundColorComboBox_SelectionChanged" />
                    </StackPanel>

                    <TextBlock x:Name="SelectedBubbleText"
                               Foreground="#55514A"
                               Margin="0,0,0,10" />

                    <TextBlock Text="선택한 말풍선 텍스트"
                               Foreground="#55514A"
                               Margin="0,0,0,6" />
                    <TextBox x:Name="SelectedBubbleTextBox"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             MinHeight="74"
                             Padding="8"
                             TextChanged="SelectedBubbleTextBox_TextChanged"
                             Margin="0,0,0,12" />

                    <TextBlock Text="말풍선 모양"
                               Foreground="#55514A"
                               Margin="0,0,0,6" />
                    <ComboBox x:Name="BubbleShapeComboBox"
                              SelectionChanged="BubbleShapeComboBox_SelectionChanged"
                              Margin="0,0,0,12">
                        <ComboBoxItem Content="원형/사각" Tag="RoundRect" IsSelected="True" />
                        <ComboBoxItem Content="구름/폭발" Tag="CloudExplosion" />
                        <ComboBoxItem Content="파도/외침" Tag="Shout" />
                        <ComboBoxItem Content="플래시" Tag="Flash" />
                        <ComboBoxItem Content="집중선" Tag="ConcentrationLines" />
                        <ComboBoxItem Content="속도선" Tag="EffectLines" />
                        <ComboBoxItem Content="테두리 없음" Tag="None" />
                    </ComboBox>

                    <TextBlock x:Name="BubbleShapeStrengthText"
                               Foreground="#55514A"
                               Margin="0,0,0,2" />
                    <Slider x:Name="BubbleShapeStrengthSlider"
                            Minimum="0"
                            Maximum="100"
                            Value="0"
                            ValueChanged="BubbleShapeStrengthSlider_ValueChanged"
                            Margin="0,0,0,10" />

                    <TextBlock x:Name="BubbleShapeCountText"
                               Foreground="#55514A"
                               Margin="0,0,0,2" />
                    <Slider x:Name="BubbleShapeCountSlider"
                            Minimum="3"
                            Maximum="30"
                            Value="9"
                            IsSnapToTickEnabled="True"
                            TickFrequency="1"
                            ValueChanged="BubbleShapeCountSlider_ValueChanged"
                            Margin="0,0,0,12" />

                    <StackPanel Visibility="Collapsed">
                        <TextBlock x:Name="BubbleWidthText" Foreground="#55514A" />
                        <Slider x:Name="BubbleWidthSlider"
                                Minimum="90"
                                Maximum="6000"
                                Value="170"
                                ValueChanged="BubbleSlider_ValueChanged"
                                Margin="0,4,0,8" />
                        <TextBlock x:Name="BubbleHeightText" Foreground="#55514A" />
                        <Slider x:Name="BubbleHeightSlider"
                                Minimum="56"
                                Maximum="6000"
                                Value="100"
                                ValueChanged="BubbleSlider_ValueChanged"
                                Margin="0,4,0,8" />
                    </StackPanel>
                    <TextBlock x:Name="BubbleFontText" Foreground="#55514A" />
                    <Slider x:Name="BubbleFontSlider"
                            Minimum="12"
                            Maximum="34"
                            Value="18"
                            ValueChanged="BubbleSlider_ValueChanged"
                            Margin="0,4,0,8" />
                    <StackPanel Visibility="Collapsed">
                        <TextBlock x:Name="BubbleXText" Foreground="#55514A" />
                        <Slider x:Name="BubbleXSlider"
                                Minimum="-240"
                                Maximum="700"
                                Value="30"
                                ValueChanged="BubbleSlider_ValueChanged"
                                Margin="0,4,0,8" />
                        <TextBlock x:Name="BubbleYText" Foreground="#55514A" />
                        <Slider x:Name="BubbleYSlider"
                                Minimum="-180"
                                Maximum="420"
                                Value="30"
                                ValueChanged="BubbleSlider_ValueChanged"
                                Margin="0,4,0,14" />
                    </StackPanel>

                    <TextBlock Text="선택한 말풍선의 꼬리"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}"
                               Margin="0,0,0,8" />
                    <ListBox x:Name="BubbleTailListBox"
                             MinHeight="72"
                             MaxHeight="130"
                             SelectionChanged="BubbleTailListBox_SelectionChanged"
                             Margin="0,0,0,8" />
                    <UniformGrid Rows="1" Columns="4" Margin="0,0,0,8">
                        <Button Content="추가"
                                Click="AddBubbleTail_Click"
                                Margin="0,0,4,0" />
                        <Button Content="삭제"
                                Click="DeleteBubbleTail_Click"
                                Margin="0,0,4,0" />
                        <Button Content="위로"
                                Click="MoveBubbleTailUp_Click"
                                Margin="0,0,4,0" />
                        <Button Content="아래로"
                                Click="MoveBubbleTailDown_Click"
                                Margin="0" />
                    </UniformGrid>
                    <CheckBox x:Name="BubbleTailInwardCheckBox"
                              Content="꼬리 안으로 깎기"
                              IsChecked="False"
                              Checked="BubbleTailInwardCheckBox_Changed"
                              Unchecked="BubbleTailInwardCheckBox_Changed"
                              Margin="0,0,0,12" />

                    <StackPanel Visibility="Collapsed">
                        <TextBlock x:Name="BubbleTailXText" Foreground="#55514A" />
                        <Slider x:Name="BubbleTailXSlider"
                                Minimum="-240"
                                Maximum="420"
                                Value="130"
                                ValueChanged="BubbleTailSlider_ValueChanged"
                                Margin="0,4,0,8" />
                        <TextBlock x:Name="BubbleTailYText" Foreground="#55514A" />
                        <Slider x:Name="BubbleTailYSlider"
                                Minimum="-180"
                                Maximum="420"
                                Value="130"
                                ValueChanged="BubbleTailSlider_ValueChanged"
                                Margin="0,4,0,8" />
                    </StackPanel>
                    <TextBlock x:Name="BubbleTailWidthText" Foreground="#55514A" />
                    <Slider x:Name="BubbleTailWidthSlider"
                            Minimum="8"
                            Maximum="80"
                            Value="28"
                            ValueChanged="BubbleTailSlider_ValueChanged"
                            Margin="0,4,0,14" />

                    <TextBlock Text="칸과 말풍선은 드래그로 이동하고, 우하단 핸들로 크기를 조절합니다."
                               TextWrapping="Wrap"
                               Foreground="#77736A"
                               Margin="0,0,0,6" />
                    <TextBlock Text="꼬리는 세 점(시작·중간·끝) 핸들로 곡선을 조절합니다. 주황 핸들(중간)을 끌면 곡선이 휩니다."
                               TextWrapping="Wrap"
                               Foreground="#77736A" />
                    </StackPanel>
                    </Border>

                    <Border Style="{StaticResource InspectorSection}">
                    <StackPanel>
                    <TextBlock Text="단축키" Style="{StaticResource SectionHeader}" />

                    <TextBlock TextWrapping="Wrap" Foreground="#55514A" Margin="0,0,0,5">
                        <Run FontWeight="Bold" Foreground="#2B6F6A">Ctrl+Z / Ctrl+Y</Run> — 실행취소 / 다시실행
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="#55514A" Margin="0,0,0,5">
                        <Run FontWeight="Bold" Foreground="#2B6F6A">Esc</Run> — 선택 해제
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="#55514A" Margin="0,0,0,5">
                        <Run FontWeight="Bold" Foreground="#2B6F6A">Delete</Run> — 선택한 이미지·말풍선 삭제
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="#55514A" Margin="0,0,0,5">
                        <Run FontWeight="Bold" Foreground="#2B6F6A">↑ / ↓</Run> — 선택 대상(칸·이미지·말풍선) 순서 이동 (선택 없으면 페이지 넘김)
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="#55514A" Margin="0,0,0,5">
                        <Run FontWeight="Bold" Foreground="#2B6F6A">마우스 휠</Run> — 페이지 넘김 (말풍선 위: 크기 조절 · 이미지 위: 확대/축소)
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="#55514A" Margin="0,0,0,5">
                        <Run FontWeight="Bold" Foreground="#2B6F6A">Ctrl+L</Run> — 선택 오브젝트 고정/해제
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="#55514A" Margin="0,0,0,5">
                        <Run FontWeight="Bold" Foreground="#2B6F6A">Ctrl+0 / Ctrl+R</Run> — 선택 리셋 (이미지=100%+좌상단 · 칸=기본 사각형 · 말풍선=텍스트 여백)
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="#55514A" Margin="0,0,0,5">
                        <Run FontWeight="Bold" Foreground="#2B6F6A">Ctrl+클릭</Run> — 고정된 오브젝트도 선택
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="#77736A">
                        커서를 올리면 클릭할 대상을 툴팁으로 보여줍니다.
                    </TextBlock>
                    </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- 인스펙터 우측 가장자리를 드래그해 폭을 조절한다(현재/다음 열을 함께 리사이즈). -->
        <GridSplitter Grid.Column="0"
                      Width="6"
                      HorizontalAlignment="Right"
                      VerticalAlignment="Stretch"
                      Background="Transparent"
                      ResizeBehavior="CurrentAndNext"
                      ResizeDirection="Columns"
                      Cursor="SizeWE" />

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <ScrollViewer Grid.Row="0"
                          x:Name="PageScrollViewer"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto"
                          Padding="28"
                          SizeChanged="PageScrollViewer_SizeChanged"
                          PreviewMouseWheel="PageScrollViewer_PreviewMouseWheel">
                <Border x:Name="PageFrame"
                        Background="#FFFFFF"
                        BorderBrush="#D7D2C8"
                        BorderThickness="1"
                        Padding="0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                    <!-- PageSurface/PageOverlay는 클리핑하지 않아 선택 UI(핸들·박스)가 페이지 밖에서도 보인다.
                         실제 콘텐츠(칸) 클리핑은 PanelCanvas가 담당한다. -->
                    <Grid x:Name="PageSurface"
                          Width="820"
                          Height="1120"
                          ClipToBounds="False"
                          Background="#FFFFFF"
                          PreviewMouseLeftButtonDown="PageSurface_PreviewMouseLeftButtonDown"
                          PreviewMouseMove="PageSurface_PreviewMouseMove"
                          MouseLeave="PageSurface_MouseLeave">
                        <Canvas x:Name="PanelCanvas"
                                Width="820"
                                Height="1120"
                                ClipToBounds="True" />
                        <Canvas x:Name="PageOverlay"
                                Width="820"
                                Height="1120"
                                ClipToBounds="False" />
                    </Grid>
                </Border>
            </ScrollViewer>

            <Button Grid.Row="0"
                    x:Name="InspectorToggleButton"
                    Content="◀"
                    Click="ToggleInspector_Click"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Width="28"
                    Height="28"
                    MinHeight="0"
                    Padding="0"
                    FontSize="13"
                    Margin="8"
                    ToolTip="인스펙터 접기/펴기" />

            <Border Grid.Row="1"
                    Background="#FFFFFF"
                    BorderBrush="#DDD8CE"
                    BorderThickness="0,1,0,0"
                    Padding="14,10">
                <DockPanel>
                    <TextBlock x:Name="StatusText"
                               DockPanel.Dock="Left"
                               VerticalAlignment="Center"
                               Foreground="#55514A"
                               Text="준비됨" />
                    <TextBlock x:Name="PageIndicatorText"
                               DockPanel.Dock="Right"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"
                               Foreground="#55514A"
                               FontWeight="SemiBold"
                               Text="페이지 1 / 1" />
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
