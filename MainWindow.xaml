<Window x:Class="NovelViewer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NovelViewer - Comic Layout"
        Width="1280"
        Height="820"
        MinWidth="980"
        MinHeight="640"
        Background="{StaticResource WindowBackgroundBrush}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="#FFFFFF"
                BorderBrush="#DDD8CE"
                BorderThickness="0,0,1,0"
                Padding="16">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="페이지"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}"
                               Margin="0,0,0,12" />
                    <ListBox x:Name="PageListBox"
                             MinHeight="86"
                             MaxHeight="150"
                             SelectionChanged="PageListBox_SelectionChanged"
                             Margin="0,0,0,8" />
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="페이지 추가"
                                Click="AddPage_Click"
                                Margin="0,0,8,0" />
                        <Button Content="삭제"
                                Click="DeletePage_Click"
                                Margin="0" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,18">
                        <Button Content="저장"
                                Click="SaveProject_Click"
                                Margin="0,0,8,0" />
                        <Button Content="불러오기"
                                Click="LoadProject_Click"
                                Margin="0" />
                    </StackPanel>

                    <TextBlock Text="칸"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}"
                               Margin="0,0,0,12" />

                    <TextBlock Text="기본 칸 구성"
                               Foreground="#55514A"
                               Margin="0,0,0,6" />
                    <DockPanel Margin="0,0,0,12">
                        <TextBox x:Name="LayoutPatternTextBox"
                                 Text="1,2,1"
                                 MinHeight="34"
                                 Padding="8,5"
                                 VerticalContentAlignment="Center" />
                        <Button Content="생성"
                                DockPanel.Dock="Right"
                                Margin="8,0,0,0"
                                Click="ApplyLayout_Click" />
                    </DockPanel>

                    <TextBlock x:Name="LayoutSummaryText"
                               Foreground="#55514A"
                               Margin="0,0,0,12" />

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Button Content="칸 추가"
                                Click="AddPanel_Click"
                                Margin="0,0,8,0" />
                        <Button Content="삭제"
                                Click="DeletePanel_Click"
                                Margin="0" />
                    </StackPanel>

                    <TextBlock Text="선택한 칸"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}"
                               Margin="0,0,0,8" />
                    <ListBox x:Name="PanelListBox"
                             MinHeight="100"
                             MaxHeight="170"
                             SelectionChanged="PanelListBox_SelectionChanged"
                             Margin="0,0,0,8" />
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Button Content="위로"
                                Click="MovePanelUp_Click"
                                Margin="0,0,8,0" />
                        <Button Content="아래로"
                                Click="MovePanelDown_Click"
                                Margin="0" />
                    </StackPanel>

                    <Button Content="선택한 칸에 이미지 넣기"
                            Click="AddImageToPanel_Click"
                            Margin="0,0,0,8" />
                    <Button Content="선택한 칸 이미지 제거"
                            Click="ClearPanelImage_Click"
                            Margin="0,0,0,18" />

                    <TextBlock Text="선택한 칸의 이미지"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}"
                               Margin="0,0,0,8" />
                    <ListBox x:Name="ImageListBox"
                             MinHeight="86"
                             MaxHeight="150"
                             SelectionChanged="ImageListBox_SelectionChanged"
                             Margin="0,0,0,8" />
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,18">
                        <Button Content="위로"
                                Click="MoveImageUp_Click"
                                Margin="0,0,8,0" />
                        <Button Content="아래로"
                                Click="MoveImageDown_Click"
                                Margin="0" />
                    </StackPanel>

                    <TextBlock Text="칸 위치와 크기"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}"
                               Margin="0,0,0,8" />
                    <TextBlock x:Name="PanelXText" Foreground="#55514A" />
                    <Slider x:Name="PanelXSlider"
                            Minimum="0"
                            Maximum="760"
                            Value="40"
                            ValueChanged="PanelSlider_ValueChanged"
                            Margin="0,4,0,8" />
                    <TextBlock x:Name="PanelYText" Foreground="#55514A" />
                    <Slider x:Name="PanelYSlider"
                            Minimum="0"
                            Maximum="1040"
                            Value="40"
                            ValueChanged="PanelSlider_ValueChanged"
                            Margin="0,4,0,8" />
                    <TextBlock x:Name="PanelWidthText" Foreground="#55514A" />
                    <Slider x:Name="PanelWidthSlider"
                            Minimum="120"
                            Maximum="760"
                            Value="340"
                            ValueChanged="PanelSlider_ValueChanged"
                            Margin="0,4,0,8" />
                    <TextBlock x:Name="PanelHeightText" Foreground="#55514A" />
                    <Slider x:Name="PanelHeightSlider"
                            Minimum="120"
                            Maximum="520"
                            Value="300"
                            ValueChanged="PanelSlider_ValueChanged"
                            Margin="0,4,0,18" />

                    <TextBlock Text="말풍선"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}"
                               Margin="0,0,0,12" />
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Button Content="말풍선 추가"
                                Click="AddBubble_Click"
                                Margin="0,0,8,0" />
                        <Button Content="삭제"
                                Click="DeleteBubble_Click"
                                Margin="0" />
                    </StackPanel>

                    <TextBlock Text="선택한 말풍선의 꼬리"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}"
                               Margin="0,0,0,8" />
                    <ListBox x:Name="BubbleTailListBox"
                             MinHeight="72"
                             MaxHeight="130"
                             SelectionChanged="BubbleTailListBox_SelectionChanged"
                             Margin="0,0,0,8" />
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Button Content="꼬리 추가"
                                Click="AddBubbleTail_Click"
                                Margin="0,0,8,0" />
                        <Button Content="삭제"
                                Click="DeleteBubbleTail_Click"
                                Margin="0" />
                    </StackPanel>

                    <TextBlock Text="선택한 칸의 말풍선"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}"
                               Margin="0,0,0,8" />
                    <ListBox x:Name="BubbleListBox"
                             MinHeight="86"
                             MaxHeight="150"
                             SelectionChanged="BubbleListBox_SelectionChanged"
                             Margin="0,0,0,8" />
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Button Content="위로"
                                Click="MoveBubbleUp_Click"
                                Margin="0,0,8,0" />
                        <Button Content="아래로"
                                Click="MoveBubbleDown_Click"
                                Margin="0" />
                    </StackPanel>

                    <TextBlock x:Name="SelectedBubbleText"
                               Foreground="#55514A"
                               Margin="0,0,0,10" />

                    <TextBlock Text="선택한 말풍선 텍스트"
                               Foreground="#55514A"
                               Margin="0,0,0,6" />
                    <TextBox x:Name="SelectedBubbleTextBox"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             MinHeight="74"
                             Padding="8"
                             TextChanged="SelectedBubbleTextBox_TextChanged"
                             Margin="0,0,0,12" />

                    <CheckBox x:Name="BubbleCropCheckBox"
                              Content="칸 경계에서 자르기"
                              IsChecked="False"
                              Checked="BubbleCropCheckBox_Changed"
                              Unchecked="BubbleCropCheckBox_Changed"
                              Margin="0,0,0,12" />

                    <TextBlock Text="말풍선 모양"
                               Foreground="#55514A"
                               Margin="0,0,0,6" />
                    <ComboBox x:Name="BubbleShapeComboBox"
                              SelectionChanged="BubbleShapeComboBox_SelectionChanged"
                              Margin="0,0,0,12">
                        <ComboBoxItem Content="원형" Tag="Oval" IsSelected="True" />
                        <ComboBoxItem Content="네모" Tag="Rectangle" />
                        <ComboBoxItem Content="구름" Tag="Cloud" />
                        <ComboBoxItem Content="외침" Tag="Shout" />
                    </ComboBox>

                    <TextBlock x:Name="BubbleWidthText" Foreground="#55514A" />
                    <Slider x:Name="BubbleWidthSlider"
                            Minimum="90"
                            Maximum="360"
                            Value="170"
                            ValueChanged="BubbleSlider_ValueChanged"
                            Margin="0,4,0,8" />
                    <TextBlock x:Name="BubbleHeightText" Foreground="#55514A" />
                    <Slider x:Name="BubbleHeightSlider"
                            Minimum="56"
                            Maximum="240"
                            Value="100"
                            ValueChanged="BubbleSlider_ValueChanged"
                            Margin="0,4,0,8" />
                    <TextBlock x:Name="BubbleFontText" Foreground="#55514A" />
                    <Slider x:Name="BubbleFontSlider"
                            Minimum="12"
                            Maximum="34"
                            Value="18"
                            ValueChanged="BubbleSlider_ValueChanged"
                            Margin="0,4,0,8" />
                    <TextBlock x:Name="BubbleXText" Foreground="#55514A" />
                    <Slider x:Name="BubbleXSlider"
                            Minimum="-240"
                            Maximum="700"
                            Value="30"
                            ValueChanged="BubbleSlider_ValueChanged"
                            Margin="0,4,0,8" />
                    <TextBlock x:Name="BubbleYText" Foreground="#55514A" />
                    <Slider x:Name="BubbleYSlider"
                            Minimum="-180"
                            Maximum="420"
                            Value="30"
                            ValueChanged="BubbleSlider_ValueChanged"
                            Margin="0,4,0,14" />

                    <TextBlock x:Name="BubbleTailXText" Foreground="#55514A" />
                    <Slider x:Name="BubbleTailXSlider"
                            Minimum="-240"
                            Maximum="420"
                            Value="130"
                            ValueChanged="BubbleTailSlider_ValueChanged"
                            Margin="0,4,0,8" />
                    <TextBlock x:Name="BubbleTailYText" Foreground="#55514A" />
                    <Slider x:Name="BubbleTailYSlider"
                            Minimum="-180"
                            Maximum="420"
                            Value="130"
                            ValueChanged="BubbleTailSlider_ValueChanged"
                            Margin="0,4,0,8" />
                    <TextBlock x:Name="BubbleTailWidthText" Foreground="#55514A" />
                    <Slider x:Name="BubbleTailWidthSlider"
                            Minimum="8"
                            Maximum="80"
                            Value="28"
                            ValueChanged="BubbleTailSlider_ValueChanged"
                            Margin="0,4,0,14" />

                    <TextBlock Text="칸과 말풍선은 드래그로 이동하고, 우하단 핸들로 크기를 조절합니다."
                               TextWrapping="Wrap"
                               Foreground="#77736A" />
                </StackPanel>
            </ScrollViewer>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <ScrollViewer Grid.Row="0"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto"
                          Padding="28">
                <Border Background="#FFFFFF"
                        BorderBrush="#D7D2C8"
                        BorderThickness="1"
                        Padding="18"
                        HorizontalAlignment="Center">
                    <Grid x:Name="PageSurface"
                          Width="820"
                          Height="1120"
                          ClipToBounds="True"
                          Background="#FFFFFF">
                        <Canvas x:Name="PanelCanvas"
                                Width="820"
                                Height="1120"
                                ClipToBounds="True" />
                        <Canvas x:Name="PageOverlay"
                                Width="820"
                                Height="1120"
                                ClipToBounds="True" />
                    </Grid>
                </Border>
            </ScrollViewer>

            <Border Grid.Row="1"
                    Background="#FFFFFF"
                    BorderBrush="#DDD8CE"
                    BorderThickness="0,1,0,0"
                    Padding="14,10">
                <DockPanel>
                    <TextBlock x:Name="StatusText"
                               DockPanel.Dock="Left"
                               VerticalAlignment="Center"
                               Foreground="#55514A"
                               Text="준비됨" />
                    <TextBlock DockPanel.Dock="Right"
                               VerticalAlignment="Center"
                               Foreground="#55514A"
                               Text="NovelViewer" />
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
