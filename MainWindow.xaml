<Window x:Class="KomaForge.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KomaForge v0.1.0 - Comic Layout"
        Width="1280"
        Height="820"
        MinWidth="980"
        MinHeight="640"
        Background="{StaticResource WindowBackgroundBrush}">
    <DockPanel>
        <Menu DockPanel.Dock="Top" Background="#F3F0EA">
            <MenuItem Header="파일(_F)">
                <MenuItem x:Name="OpenMenuItem" Header="불러오기..." InputGestureText="Ctrl+O" Click="LoadProject_Click" />
                <MenuItem x:Name="SaveMenuItem" Header="저장" InputGestureText="Ctrl+S" Click="SaveMenuItem_Click" />
                <MenuItem Header="다른 이름으로 저장..." Click="SaveProject_Click" />
                <Separator />
                <MenuItem Header="페이지 이미지로 내보내기..." Click="ExportPagesAsImages_Click" />
                <Separator />
                <MenuItem x:Name="PreferencesMenuItem" Header="환경설정..." InputGestureText="Ctrl+," Click="Preferences_Click" />
                <Separator />
                <MenuItem Header="종료" Click="ExitMenuItem_Click" />
            </MenuItem>
            <MenuItem Header="편집(_E)">
                <MenuItem x:Name="UndoMenuItem" Header="실행취소" InputGestureText="Ctrl+Z" Click="Undo_Click" />
                <MenuItem x:Name="RedoMenuItem" Header="다시실행" InputGestureText="Ctrl+Y" Click="Redo_Click" />
                <Separator />
                <MenuItem x:Name="CutMenuItem" Header="잘라내기" InputGestureText="Ctrl+X" Click="Cut_Click" />
                <MenuItem x:Name="CopyMenuItem" Header="복사" InputGestureText="Ctrl+C" Click="Copy_Click" />
                <MenuItem x:Name="PasteMenuItem" Header="붙여넣기" InputGestureText="Ctrl+V" Click="Paste_Click" />
            </MenuItem>
            <MenuItem Header="보기(_V)">
                <MenuItem x:Name="PageFitMenuItem"
                          Header="페이지 쪽 맞춤"
                          IsCheckable="True"
                          Checked="PageFitCheckBox_Changed"
                          Unchecked="PageFitCheckBox_Changed" />
            </MenuItem>
        </Menu>
        <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="InspectorColumn" Width="360" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border x:Name="InspectorPanel"
                Grid.Column="0"
                Background="#FFFFFF"
                BorderBrush="#DDD8CE"
                BorderThickness="0,0,1,0"
                Padding="16">
            <ScrollViewer x:Name="InspectorScrollViewer"
                          VerticalScrollBarVisibility="Auto"
                          PreviewMouseWheel="InspectorScrollViewer_PreviewMouseWheel">
                <StackPanel Margin="0,0,12,0">
                    <TextBlock Text="설명"
                               Foreground="#55514A"
                               Margin="0,0,0,6" />
                    <TextBox x:Name="ComicTitleTextBox"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Disabled"
                             Padding="6,2"
                             TextChanged="ComicTitleTextBox_TextChanged"
                             Margin="0,0,0,18" />

                    <Border x:Name="PageSectionBorder"
                            Style="{StaticResource InspectorSection}"
                            IsKeyboardFocusWithinChanged="PageSection_FocusChanged">
                    <StackPanel>
                    <TextBlock Text="페이지" Style="{StaticResource SectionHeader}" />
                    <ListBox x:Name="PageListBox"
                             MinHeight="86"
                             MaxHeight="150"
                             AlternationCount="10000"
                             SelectionChanged="PageListBox_SelectionChanged"
                             MouseDoubleClick="PageListBox_MouseDoubleClick"
                             PreviewKeyDown="PageListBox_PreviewKeyDown"
                             Margin="0,0,0,8">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <!-- 표시: "1. 이름" (번호는 항목 위치). 편집 중이면 숨김. -->
                                    <StackPanel Orientation="Horizontal">
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>
                                        <TextBlock Text="{Binding (ItemsControl.AlternationIndex), RelativeSource={RelativeSource AncestorType=ListBoxItem}, Converter={StaticResource AddOneConverter}}" />
                                        <TextBlock Text=". " />
                                        <TextBlock Text="{Binding Name}" />
                                    </StackPanel>
                                    <!-- 편집: 더블클릭/F2 시 표시되는 입력칸(기본 숨김은 Style로 — 로컬 값은 트리거를 덮어쓰므로). -->
                                    <TextBox Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             Padding="2,0"
                                             IsVisibleChanged="PageRenameBox_IsVisibleChanged"
                                             KeyDown="PageRenameBox_KeyDown"
                                             LostFocus="PageRenameBox_LostFocus">
                                        <TextBox.Style>
                                            <Style TargetType="TextBox">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBox.Style>
                                    </TextBox>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <UniformGrid Rows="1" Columns="4" Margin="0,0,0,18">
                        <Button Content="추가"
                                Click="AddPage_Click"
                                Margin="0,0,4,0" />
                        <Button Content="삭제"
                                Click="DeletePage_Click"
                                Margin="0,0,4,0" />
                        <Button Content="위로"
                                Click="MovePageUp_Click"
                                Margin="0,0,4,0" />
                        <Button Content="아래로"
                                Click="MovePageDown_Click"
                                Margin="0" />
                    </UniformGrid>

                    <!-- 페이지 리스트에 포커스가 있을 때만 보이는 하위 옵션 -->
                    <StackPanel x:Name="PageEditControls" Visibility="Collapsed">
                    <TextBlock Text="페이지 크기 (너비 × 높이)"
                               Foreground="#55514A"
                               Margin="0,0,0,6" />
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="PageWidthTextBox"
                                 Grid.Column="0"
                                 Text="832"
                                 Padding="6,2"
                                 VerticalContentAlignment="Center"
                                 TextChanged="PageSizeTextBox_TextChanged" />
                        <TextBlock Text="×"
                                   Grid.Column="1"
                                   VerticalAlignment="Center"
                                   Margin="6,0"
                                   Foreground="#55514A" />
                        <TextBox x:Name="PageHeightTextBox"
                                 Grid.Column="2"
                                 Text="1216"
                                 Padding="6,2"
                                 VerticalContentAlignment="Center"
                                 TextChanged="PageSizeTextBox_TextChanged" />
                    </Grid>
                    <CheckBox x:Name="BlackBackgroundCheckBox"
                              Content="페이지 배경 검은색"
                              IsChecked="False"
                              Checked="BlackBackgroundCheckBox_Changed"
                              Unchecked="BlackBackgroundCheckBox_Changed"
                              Margin="0,2,0,14" />

                    <TextBlock Text="칸 구성 / 여백 / 간격"
                               Foreground="#55514A"
                               Margin="0,0,0,6" />
                    <UniformGrid Rows="1" Columns="3" Margin="0,0,0,8">
                        <TextBox x:Name="LayoutPatternTextBox"
                                 Text="1,2,1"
                                 Padding="6,2"
                                 VerticalContentAlignment="Center"
                                 Margin="0,0,4,0"
                                 ToolTip="칸 구성 (예: 1,2,1)" />
                        <TextBox x:Name="AutoMarginTextBox"
                                 Text="24"
                                 Padding="6,2"
                                 VerticalContentAlignment="Center"
                                 Margin="0,0,4,0"
                                 ToolTip="자동 생성 여백" />
                        <TextBox x:Name="AutoGutterTextBox"
                                 Text="14"
                                 Padding="6,2"
                                 VerticalContentAlignment="Center"
                                 Margin="0"
                                 ToolTip="자동 생성 간격" />
                    </UniformGrid>
                    <Button Content="구성"
                            Click="ApplyLayout_Click"
                            HorizontalAlignment="Stretch"
                            Margin="0,0,0,8" />

                    <TextBlock x:Name="LayoutSummaryText"
                               Foreground="#55514A"
                               Margin="0,0,0,0" />
                    </StackPanel>
                    </StackPanel>
                    </Border>

                    <Border x:Name="PanelSectionBorder" Style="{StaticResource InspectorSection}">
                    <StackPanel>
                    <TextBlock Text="칸" Style="{StaticResource SectionHeader}" />

                    <ListBox x:Name="PanelListBox"
                             MinHeight="100"
                             MaxHeight="170"
                             SelectionChanged="PanelListBox_SelectionChanged"
                             MouseDoubleClick="PanelListBox_MouseDoubleClick"
                             PreviewKeyDown="PanelListBox_PreviewKeyDown"
                             Margin="0,0,0,8">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <!-- 표시: 잠금 아이콘 + 이름(비어 있으면 "N번 칸"). 편집 중이면 숨김. -->
                                    <TextBlock Text="{Binding DisplayText}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <!-- 편집: 더블클릭/F2 시 표시되는 입력칸(기본 숨김은 Style로 — 로컬 값은 트리거를 덮어쓰므로). -->
                                    <TextBox Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             Padding="2,0"
                                             IsVisibleChanged="PageRenameBox_IsVisibleChanged"
                                             KeyDown="PanelRenameBox_KeyDown"
                                             LostFocus="PanelRenameBox_LostFocus">
                                        <TextBox.Style>
                                            <Style TargetType="TextBox">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBox.Style>
                                    </TextBox>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <UniformGrid Rows="1" Columns="4" Margin="0,0,0,12">
                        <Button Content="추가"
                                Click="AddPanel_Click"
                                Margin="0,0,4,0" />
                        <Button Content="삭제"
                                Click="DeletePanel_Click"
                                Margin="0,0,4,0" />
                        <Button Content="위로"
                                Click="MovePanelUp_Click"
                                Margin="0,0,4,0" />
                        <Button Content="아래로"
                                Click="MovePanelDown_Click"
                                Margin="0" />
                    </UniformGrid>
                    <!-- 칸이 선택되지 않으면 아래 옵션을 숨긴다(리스트만 표시). -->
                    <StackPanel x:Name="PanelEditControls" Visibility="Collapsed">
                    <CheckBox x:Name="PanelLockCheckBox"
                              Content="잠금 (선택·이동 막기)"
                              IsChecked="False"
                              Checked="PanelLockCheckBox_Changed"
                              Unchecked="PanelLockCheckBox_Changed"
                              Margin="0,0,0,8" />
                    <CheckBox x:Name="PanelCornerModeCheckBox"
                              Content="모서리 조절 (사변형)"
                              IsChecked="False"
                              Checked="PanelCornerModeCheckBox_Changed"
                              Unchecked="PanelCornerModeCheckBox_Changed"
                              Margin="0,0,0,0" />
                    </StackPanel>
                    </StackPanel>
                    </Border>

                    <Border x:Name="ImageSectionBorder" Style="{StaticResource InspectorSection}" Visibility="Collapsed">
                    <StackPanel>
                    <TextBlock Text="이미지" Style="{StaticResource SectionHeader}" />
                    <ListBox x:Name="ImageListBox"
                             MinHeight="86"
                             MaxHeight="150"
                             SelectionChanged="ImageListBox_SelectionChanged"
                             Margin="0,0,0,8" />
                    <UniformGrid Rows="1" Columns="4" Margin="0,0,0,18">
                        <Button Content="추가"
                                Click="AddImageToPanel_Click"
                                Margin="0,0,4,0" />
                        <Button Content="삭제"
                                Click="ClearPanelImage_Click"
                                Margin="0,0,4,0" />
                        <Button Content="위로"
                                Click="MoveImageUp_Click"
                                Margin="0,0,4,0" />
                        <Button Content="아래로"
                                Click="MoveImageDown_Click"
                                Margin="0" />
                    </UniformGrid>
                    <!-- 이미지가 선택되지 않으면 아래 옵션을 숨긴다(리스트만 표시). -->
                    <StackPanel x:Name="ImageEditControls" Visibility="Collapsed">
                    <CheckBox x:Name="ImageLockCheckBox"
                              Content="잠금 (선택·이동 막기)"
                              IsChecked="False"
                              Checked="ImageLockCheckBox_Changed"
                              Unchecked="ImageLockCheckBox_Changed"
                              Margin="0,0,0,8" />
                    <CheckBox x:Name="ImageCropCheckBox"
                              Content="칸 경계에서 자르기"
                              IsChecked="True"
                              Checked="ImageCropCheckBox_Changed"
                              Unchecked="ImageCropCheckBox_Changed"
                              Margin="0,0,0,8" />
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,18">
                        <TextBlock Text="기준점"
                                   Width="64"
                                   VerticalAlignment="Center"
                                   Foreground="#55514A"
                                   Background="Transparent"
                                   ToolTip="X: 0=좌 1=우 / Y: 0=하 1=상 (칸 크기 조절 시 따라갈 위치)" />
                        <TextBox x:Name="ImagePivotXBox" Width="44" Text="0" TextChanged="ImagePivotBox_Changed" />
                        <TextBlock Text="," VerticalAlignment="Center" Margin="4,0" Foreground="#55514A" />
                        <TextBox x:Name="ImagePivotYBox" Width="44" Text="1" TextChanged="ImagePivotBox_Changed" />
                    </StackPanel>
                    </StackPanel>

                    <StackPanel Visibility="Collapsed">
                        <TextBlock Text="칸 위치와 크기"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextBrush}"
                                   Margin="0,0,0,8" />
                        <TextBlock x:Name="PanelXText" Foreground="#55514A" />
                        <Slider x:Name="PanelXSlider"
                                Minimum="0"
                                Maximum="760"
                                Value="40"
                                ValueChanged="PanelSlider_ValueChanged"
                                Margin="0,4,0,8" />
                        <TextBlock x:Name="PanelYText" Foreground="#55514A" />
                        <Slider x:Name="PanelYSlider"
                                Minimum="0"
                                Maximum="1040"
                                Value="40"
                                ValueChanged="PanelSlider_ValueChanged"
                                Margin="0,4,0,8" />
                        <TextBlock x:Name="PanelWidthText" Foreground="#55514A" />
                        <Slider x:Name="PanelWidthSlider"
                                Minimum="120"
                                Maximum="760"
                                Value="340"
                                ValueChanged="PanelSlider_ValueChanged"
                                Margin="0,4,0,8" />
                        <TextBlock x:Name="PanelHeightText" Foreground="#55514A" />
                        <Slider x:Name="PanelHeightSlider"
                                Minimum="120"
                                Maximum="520"
                                Value="300"
                                ValueChanged="PanelSlider_ValueChanged"
                                Margin="0,4,0,18" />
                    </StackPanel>
                    </StackPanel>
                    </Border>

                    <Border x:Name="BubbleSectionBorder" Style="{StaticResource InspectorSection}" Visibility="Collapsed">
                    <StackPanel>
                    <TextBlock Text="말풍선" Style="{StaticResource SectionHeader}" />
                    <ListBox x:Name="BubbleListBox"
                             MinHeight="86"
                             MaxHeight="150"
                             SelectionChanged="BubbleListBox_SelectionChanged"
                             Margin="0,0,0,8" />
                    <UniformGrid Rows="1" Columns="4" Margin="0,0,0,12">
                        <Button Content="추가"
                                Click="AddBubble_Click"
                                Margin="0,0,4,0" />
                        <Button Content="삭제"
                                Click="DeleteBubble_Click"
                                Margin="0,0,4,0" />
                        <Button Content="위로"
                                Click="MoveBubbleUp_Click"
                                Margin="0,0,4,0" />
                        <Button Content="아래로"
                                Click="MoveBubbleDown_Click"
                                Margin="0" />
                    </UniformGrid>
                    <!-- 말풍선이 선택되지 않으면 아래 편집 옵션 전체를 숨긴다(리스트만 표시). -->
                    <StackPanel x:Name="BubbleEditControls" Visibility="Collapsed">
                    <CheckBox x:Name="BubbleLockCheckBox"
                              Content="잠금 (선택·이동 막기)"
                              IsChecked="False"
                              Checked="BubbleLockCheckBox_Changed"
                              Unchecked="BubbleLockCheckBox_Changed"
                              Margin="0,0,0,8" />
                    <CheckBox x:Name="BubbleCropCheckBox"
                              Content="칸 경계에서 자르기"
                              IsChecked="True"
                              Checked="BubbleCropCheckBox_Changed"
                              Unchecked="BubbleCropCheckBox_Changed"
                              Margin="0,0,0,8" />
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock Text="기준점"
                                   Width="64"
                                   VerticalAlignment="Center"
                                   Foreground="#55514A"
                                   Background="Transparent"
                                   ToolTip="X: 0=좌 1=우 / Y: 0=하 1=상 (칸 크기 조절 시 따라갈 위치)" />
                        <TextBox x:Name="BubblePivotXBox" Width="44" Text="0" TextChanged="BubblePivotBox_Changed" />
                        <TextBlock Text="," VerticalAlignment="Center" Margin="4,0" Foreground="#55514A" />
                        <TextBox x:Name="BubblePivotYBox" Width="44" Text="1" TextChanged="BubblePivotBox_Changed" />
                    </StackPanel>
                    <Border Style="{StaticResource InspectorGroup}">
                    <StackPanel>
                    <TextBlock Text="텍스트 · 색상" Style="{StaticResource GroupHeader}" />
                    <TextBlock Text="말풍선 텍스트"
                               Foreground="#55514A"
                               Margin="0,0,0,6" />
                    <TextBox x:Name="SelectedBubbleTextBox"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             MinHeight="74"
                             Padding="8"
                             TextChanged="SelectedBubbleTextBox_TextChanged"
                             Margin="0,0,0,12" />

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock Text="글자 크기"
                                   Width="64"
                                   VerticalAlignment="Center"
                                   Foreground="#55514A" />
                        <TextBox x:Name="BubbleFontBox"
                                 Width="60"
                                 Text="18"
                                 Padding="6,2"
                                 VerticalContentAlignment="Center"
                                 TextChanged="BubbleFontBox_TextChanged" />
                        <TextBlock Text="px"
                                   VerticalAlignment="Center"
                                   Margin="6,0,0,0"
                                   Foreground="#55514A" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock Text="글자색"
                                   Width="64"
                                   VerticalAlignment="Center"
                                   Foreground="#55514A" />
                        <ComboBox x:Name="BubbleFillColorComboBox"
                                  Width="130"
                                  SelectionChanged="BubbleFillColorComboBox_SelectionChanged" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock Text="배경색"
                                   Width="64"
                                   VerticalAlignment="Center"
                                   Foreground="#55514A" />
                        <ComboBox x:Name="BubbleBackgroundColorComboBox"
                                  Width="130"
                                  SelectionChanged="BubbleBackgroundColorComboBox_SelectionChanged" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock Text="아웃라인색"
                                   Width="64"
                                   VerticalAlignment="Center"
                                   Foreground="#55514A" />
                        <ComboBox x:Name="BubbleStrokeColorComboBox"
                                  Width="130"
                                  SelectionChanged="BubbleStrokeColorComboBox_SelectionChanged" />
                    </StackPanel>
                    </StackPanel>
                    </Border>

                    <Border Style="{StaticResource InspectorGroup}">
                    <StackPanel>
                    <TextBlock Text="모양" Style="{StaticResource GroupHeader}" />
                    <TextBlock Text="말풍선 모양"
                               Foreground="#55514A"
                               Margin="0,0,0,6" />
                    <ComboBox x:Name="BubbleShapeComboBox"
                              SelectionChanged="BubbleShapeComboBox_SelectionChanged"
                              Margin="0,0,0,12">
                        <ComboBoxItem Content="원형/사각" Tag="RoundRect" IsSelected="True" />
                        <ComboBoxItem Content="구름/폭발" Tag="CloudExplosion" />
                        <ComboBoxItem Content="플래시" Tag="Flash" />
                        <ComboBoxItem Content="집중선" Tag="ConcentrationLines" />
                        <ComboBoxItem Content="속도선" Tag="EffectLines" />
                        <ComboBoxItem Content="테두리 없음" Tag="None" />
                    </ComboBox>

                    <TextBlock x:Name="BubbleShapeStrengthText"
                               Foreground="#55514A"
                               Margin="0,0,0,2" />
                    <Slider x:Name="BubbleShapeStrengthSlider"
                            Minimum="0"
                            Maximum="100"
                            Value="0"
                            ValueChanged="BubbleShapeStrengthSlider_ValueChanged"
                            Margin="0,0,0,10" />

                    <TextBlock x:Name="BubbleShapeCountText"
                               Foreground="#55514A"
                               Margin="0,0,0,2" />
                    <Slider x:Name="BubbleShapeCountSlider"
                            Minimum="3"
                            Maximum="100"
                            Value="9"
                            IsSnapToTickEnabled="True"
                            TickFrequency="1"
                            ValueChanged="BubbleShapeCountSlider_ValueChanged"
                            Margin="0,0,0,12" />

                    <TextBlock x:Name="BubbleShapeIrregularityText"
                               Foreground="#55514A"
                               Margin="0,0,0,2" />
                    <Slider x:Name="BubbleShapeIrregularitySlider"
                            Minimum="0"
                            Maximum="100"
                            Value="50"
                            ValueChanged="BubbleShapeIrregularitySlider_ValueChanged"
                            Margin="0,0,0,12" />

                    <TextBlock x:Name="BubbleShapeWidthVarText"
                               Foreground="#55514A"
                               Margin="0,0,0,2" />
                    <Slider x:Name="BubbleShapeWidthVarSlider"
                            Minimum="0"
                            Maximum="100"
                            Value="0"
                            ValueChanged="BubbleShapeWidthVarSlider_ValueChanged"
                            Margin="0,0,0,2" />
                    </StackPanel>
                    </Border>

                    <StackPanel Visibility="Collapsed">
                        <TextBlock x:Name="BubbleWidthText" Foreground="#55514A" />
                        <Slider x:Name="BubbleWidthSlider"
                                Minimum="90"
                                Maximum="6000"
                                Value="170"
                                ValueChanged="BubbleSlider_ValueChanged"
                                Margin="0,4,0,8" />
                        <TextBlock x:Name="BubbleHeightText" Foreground="#55514A" />
                        <Slider x:Name="BubbleHeightSlider"
                                Minimum="56"
                                Maximum="6000"
                                Value="100"
                                ValueChanged="BubbleSlider_ValueChanged"
                                Margin="0,4,0,8" />
                    </StackPanel>
                    <StackPanel Visibility="Collapsed">
                        <TextBlock x:Name="BubbleXText" Foreground="#55514A" />
                        <Slider x:Name="BubbleXSlider"
                                Minimum="-240"
                                Maximum="700"
                                Value="30"
                                ValueChanged="BubbleSlider_ValueChanged"
                                Margin="0,4,0,8" />
                        <TextBlock x:Name="BubbleYText" Foreground="#55514A" />
                        <Slider x:Name="BubbleYSlider"
                                Minimum="-180"
                                Maximum="420"
                                Value="30"
                                ValueChanged="BubbleSlider_ValueChanged"
                                Margin="0,4,0,14" />
                    </StackPanel>

                    <Border Style="{StaticResource InspectorGroup}">
                    <StackPanel>
                    <TextBlock Text="꼬리" Style="{StaticResource GroupHeader}" />
                    <ListBox x:Name="BubbleTailListBox"
                             MinHeight="72"
                             MaxHeight="130"
                             SelectionChanged="BubbleTailListBox_SelectionChanged"
                             Margin="0,0,0,8" />
                    <UniformGrid Rows="1" Columns="4" Margin="0,0,0,8">
                        <Button Content="추가"
                                Click="AddBubbleTail_Click"
                                Margin="0,0,4,0" />
                        <Button Content="삭제"
                                Click="DeleteBubbleTail_Click"
                                Margin="0,0,4,0" />
                        <Button Content="위로"
                                Click="MoveBubbleTailUp_Click"
                                Margin="0,0,4,0" />
                        <Button Content="아래로"
                                Click="MoveBubbleTailDown_Click"
                                Margin="0" />
                    </UniformGrid>
                    <CheckBox x:Name="BubbleTailInwardCheckBox"
                              Content="꼬리 안으로 깎기"
                              IsChecked="False"
                              Checked="BubbleTailInwardCheckBox_Changed"
                              Unchecked="BubbleTailInwardCheckBox_Changed"
                              Margin="0,0,0,12" />

                    <StackPanel Visibility="Collapsed">
                        <TextBlock x:Name="BubbleTailXText" Foreground="#55514A" />
                        <Slider x:Name="BubbleTailXSlider"
                                Minimum="-240"
                                Maximum="420"
                                Value="130"
                                ValueChanged="BubbleTailSlider_ValueChanged"
                                Margin="0,4,0,8" />
                        <TextBlock x:Name="BubbleTailYText" Foreground="#55514A" />
                        <Slider x:Name="BubbleTailYSlider"
                                Minimum="-180"
                                Maximum="420"
                                Value="130"
                                ValueChanged="BubbleTailSlider_ValueChanged"
                                Margin="0,4,0,8" />
                    </StackPanel>
                    <TextBlock x:Name="BubbleTailWidthText" Foreground="#55514A" />
                    <Slider x:Name="BubbleTailWidthSlider"
                            Minimum="8"
                            Maximum="80"
                            Value="28"
                            ValueChanged="BubbleTailSlider_ValueChanged"
                            Margin="0,4,0,14" />
                    <TextBlock Text="꼬리는 세 점(시작·중간·끝) 핸들로 곡선을 조절합니다. 주황 핸들(중간)을 끌면 곡선이 휩니다."
                               TextWrapping="Wrap"
                               Foreground="#77736A"
                               Margin="0,2,0,0" />
                    </StackPanel>
                    </Border>
                    </StackPanel>
                    </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- 인스펙터 우측 가장자리를 드래그해 폭을 조절한다(현재/다음 열을 함께 리사이즈). -->
        <GridSplitter Grid.Column="0"
                      Width="6"
                      HorizontalAlignment="Right"
                      VerticalAlignment="Stretch"
                      Background="Transparent"
                      ResizeBehavior="CurrentAndNext"
                      ResizeDirection="Columns"
                      Cursor="SizeWE" />

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <ScrollViewer Grid.Row="0"
                          x:Name="PageScrollViewer"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto"
                          Padding="28"
                          Background="Transparent"
                          SizeChanged="PageScrollViewer_SizeChanged"
                          PreviewMouseLeftButtonDown="PageScrollViewer_PreviewMouseLeftButtonDown"
                          PreviewMouseWheel="PageScrollViewer_PreviewMouseWheel">
                <Border x:Name="PageFrame"
                        Background="#FFFFFF"
                        BorderBrush="#D7D2C8"
                        BorderThickness="1"
                        Padding="0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                    <!-- PageSurface/PageOverlay는 클리핑하지 않아 선택 UI(핸들·박스)가 페이지 밖에서도 보인다.
                         실제 콘텐츠(칸) 클리핑은 PanelCanvas가 담당한다. -->
                    <Grid x:Name="PageSurface"
                          Width="832"
                          Height="1216"
                          ClipToBounds="False"
                          Background="#FFFFFF"
                          PreviewMouseMove="PageSurface_PreviewMouseMove"
                          MouseLeave="PageSurface_MouseLeave">
                        <Canvas x:Name="PanelCanvas"
                                Width="832"
                                Height="1216"
                                ClipToBounds="True" />
                        <Canvas x:Name="PageOverlay"
                                Width="832"
                                Height="1216"
                                ClipToBounds="False" />
                    </Grid>
                </Border>
            </ScrollViewer>

            <Button Grid.Row="0"
                    x:Name="InspectorToggleButton"
                    Content="◀"
                    Click="ToggleInspector_Click"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Width="28"
                    Height="28"
                    MinHeight="0"
                    Padding="0"
                    FontSize="13"
                    Margin="8"
                    ToolTip="인스펙터 접기/펴기" />

            <Border Grid.Row="1"
                    Background="#FFFFFF"
                    BorderBrush="#DDD8CE"
                    BorderThickness="0,1,0,0"
                    Padding="14,10">
                <DockPanel>
                    <TextBlock x:Name="StatusText"
                               DockPanel.Dock="Left"
                               VerticalAlignment="Center"
                               Foreground="#55514A"
                               Text="준비됨" />
                    <TextBlock x:Name="PageIndicatorText"
                               DockPanel.Dock="Right"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"
                               Foreground="#55514A"
                               FontWeight="SemiBold"
                               Text="페이지 1 / 1" />
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
    </DockPanel>
</Window>
