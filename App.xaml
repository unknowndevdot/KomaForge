<Application x:Class="KomaForge.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#F6F3EE" />
        <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="AccentBrush" Color="#2B6F6A" />
        <SolidColorBrush x:Key="TextBrush" Color="#202124" />

        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="24" />
            <Setter Property="Padding" Value="10,2" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <!-- 인스펙터 섹션 카드(페이지/칸/말풍선 영역을 시각적으로 구분) -->
        <Style x:Key="InspectorSection" TargetType="Border">
            <Setter Property="Background" Value="#FBF9F5" />
            <Setter Property="BorderBrush" Value="#DAD3C6" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="14" />
            <Setter Property="Margin" Value="0,0,0,16" />
        </Style>

        <!-- 섹션 제목(좌측 강조 막대 + 강조색) -->
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
            <Setter Property="Padding" Value="8,0,0,0" />
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>
    </Application.Resources>
</Application>
